FROM debian/eol:sarge

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8

USER root

# 必要なツールのインストール
# 確定パッケージに加えて、新登場の GLUT ライブラリ（freeglut3-dev）と TIFF ライブラリを安全なループで確実に仕留めます。
RUN apt-get update && apt-get install -y \
    ca-certificates \
    gnupg \
    bash \
    locales \
    build-essential \
    vim \
    zlib1g-dev \
    libexpat1-dev \
    libpng12-dev \
    libjpeg62-dev \
    gtkglarea5-dev \
    f2c \
    blas-dev \
    lapack-dev \
 && for pkg in libtiff4-dev libtiff-dev freeglut3-dev libglut-dev; do \
        apt-get install -y $pkg || echo "Skipping unavailable package candidate: $pkg"; \
    done \
 && apt-get clean \
 && rm -rf /var/lib/apt/lists/*

# 作業ディレクトリの作成
WORKDIR /usr/local/src

# 手元のファイルをコピーして展開
COPY gangsrc-020918.tar.gz .
RUN tar -zxvf gangsrc-020918.tar.gz \
    && rm gangsrc-020918.tar.gz

# --- [STEP 1 対策] vector.H を std::vector ベースの「.fill() 持ち拡張クラス」として完全定義 ---
RUN cd gangsrc-020918/BASE/base \
    && printf "%s\n" \
       "#ifndef _BASE_VECTOR_H" \
       "#define _BASE_VECTOR_H" \
       "#include <vector>" \
       "#include <stddef.h>" \
       "namespace base {" \
       "  template <class T, class Alloc = std::allocator<T> >" \
       "  class vector : public std::vector<T, Alloc> {" \
       "  public:" \
       "    vector() : std::vector<T, Alloc>() {}" \
       "    explicit vector(size_t n, const T& value = T(), const Alloc& alloc = Alloc()) : std::vector<T, Alloc>(n, value, alloc) {}" \
       "    vector(const std::vector<T, Alloc>& x) : std::vector<T, Alloc>(x) {}" \
       "    vector& operator=(const std::vector<T, Alloc>& x) { std::vector<T, Alloc>::operator=(x); return *this; }" \
       "    vector& operator=(const vector& x) { std::vector<T, Alloc>::operator=(x); return *this; }" \
       "    void fill(const T& val, size_t n) { this->assign(n, val); }" \
       "  };" \
       "}" \
       "#endif" > vector.H

# --- [STEP 2 対策] slist のインクルードパスと名前空間を GCC 3.3 向けに修正 ---
RUN cd gangsrc-020918 \
    && sed -i 's|<slist>|<ext/slist>|g' BASE/base/Pool.H BASE/vrml/Parser.H \
    && sed -i 's|std::slist|__gnu_cxx::slist|g' BASE/base/Pool.H BASE/base/Pool.C BASE/vrml/Parser.H

# --- [STEP 3 対策] System.C の set_new_handler を ISO C++ 準拠に修正 ---
RUN cd gangsrc-020918/BASE/base \
    && echo '#include <new>' > System.C.tmp \
    && cat System.C >> System.C.tmp \
    && mv System.C.tmp System.C \
    && sed -i 's|set_new_handler|std::set_new_handler|g' System.C

# --- [STEP 4 対策] PrintNumber.H の中身を安全なコードに丸ごと差し替える（print/printMを追加） ---
RUN cd gangsrc-020918/BASE/base \
    && printf "%s\n" \
       "#ifndef _BASE_PRINTNUMBER_H" \
       "#define _BASE_PRINTNUMBER_H" \
       "#include <iostream>" \
       "namespace base {" \
       "  template <class A> inline void _print(std::ostream& os, const A& a, unsigned int p=0) { os << a; }" \
       "  template <class A> inline void _printM(std::ostream& os, const A& a, unsigned int p=0) { os << a; }" \
       "  template <class A> inline void print(std::ostream& os, const A& a, unsigned int p=0) { os << a; }" \
       "  template <class A> inline void printM(std::ostream& os, const A& a, unsigned int p=0) { os << a; }" \
       "}" \
       "#endif" > PrintNumber.H

# --- [STEP 5 対策] Stl.H の中身を完全上書き ---
RUN cd gangsrc-020918/BASE/base \
    && printf "%s\n" \
       "#ifndef _BASE_STL_H_FIXED" \
       "#define _BASE_STL_H_FIXED" \
       "#include \"base/vector.H\"" \
       "#include <algorithm>" \
       "namespace base {" \
       "  template <class T, class A> inline void do_2d_fill(base::vector<base::vector<T, A> >& v, const T& val) {" \
       "    for(size_t i=0; i<v.size(); ++i) {" \
       "      for(size_t j=0; j<v[i].size(); ++j) { v[i][j] = val; }" \
       "    }" \
       "  }" \
       "}" \
       "namespace base {" \
       "  inline void fill(base::vector<double>& v, double val) { std::fill(v.begin(), v.end(), val); }" \
       "  inline void fill(base::vector<double>& v, double val, unsigned int, unsigned int) { std::fill(v.begin(), v.end(), val); }" \
       "  inline void fill(base::vector<base::vector<double> >& v, double val) { base::do_2d_fill(v, val); }" \
       "  inline void fill(base::vector<base::vector<double> >& v, double val, unsigned int, unsigned int) { base::do_2d_fill(v, val); }" \
       "  template <class T, class A> inline void fill(base::vector<T, A>& v, const T& val) { std::fill(v.begin(), v.end(), val); }" \
       "  template <class T, class A> inline void fill(base::vector<T, A>& v, const T& val, unsigned int, unsigned int) { std::fill(v.begin(), v.end(), val); }" \
       "  template <class T, class A> inline void fill(base::vector<base::vector<T, A> >& v, const T& val) { base::do_2d_fill(v, val); }" \
       "  template <class T, class A> inline void fill(base::vector<base::vector<T, A> >& v, const T& val, unsigned int, unsigned int) { base::do_2d_fill(v, val); }" \
       "}" \
       "namespace math {" \
       "  inline void fill(base::vector<double>& v, double val) { std::fill(v.begin(), v.end(), val); }" \
       "  inline void fill(base::vector<double>& v, double val, unsigned int, unsigned int) { std::fill(v.begin(), v.end(), val); }" \
       "  inline void fill(base::vector<base::vector<double> >& v, double val) { base::do_2d_fill(v, val); }" \
       "  inline void fill(base::vector<base::vector<double> >& v, double val, unsigned int, unsigned int) { base::do_2d_fill(v, val); }" \
       "  template <class T, class A> inline void fill(base::vector<T, A>& v, const T& val) { std::fill(v.begin(), v.end(), val); }" \
       "  template <class T, class A> inline void fill(base::vector<T, A>& v, const T& val, unsigned int, unsigned int) { std::fill(v.begin(), v.end(), val); }" \
       "  template <class T, class A> inline void fill(base::vector<base::vector<T, A> >& v, const T& val) { base::do_2d_fill(v, val); }" \
       "  template <class T, class A> inline void fill(base::vector<base::vector<T, A> >& v, const T& val, unsigned int, unsigned int) { base::do_2d_fill(v, val); }" \
       "}" \
       "inline void fill(base::vector<double>& v, double val) { std::fill(v.begin(), v.end(), val); }" \
       "inline void fill(base::vector<double>& v, double val, unsigned int, unsigned int) { std::fill(v.begin(), v.end(), val); }" \
       "inline void fill(base::vector<base::vector<double> >& v, double val) { base::do_2d_fill(v, val); }" \
       "inline void fill(base::vector<base::vector<double> >& v, double val, unsigned int, unsigned int) { base::do_2d_fill(v, val); }" \
       "template <class T, class A> inline void fill(base::vector<T, A>& v, const T& val) { std::fill(v.begin(), v.end(), val); }" \
       "template <class T, class A> inline void fill(base::vector<T, A>& v, const T& val, unsigned int, unsigned int) { std::fill(v.begin(), v.end(), val); }" \
       "template <class T, class A> inline void fill(base::vector<base::vector<T, A> >& v, const T& val) { base::do_2d_fill(v, val); }" \
       "template <class T, class A> inline void fill(base::vector<base::vector<T, A> >& v, const T& val, unsigned int, unsigned int) { base::do_2d_fill(v, val); }" \
       "#endif" > Stl.H

# --- [STEP 6 対策] Parser.C に見当たらない assert.h を明示的にインクルード ---
RUN cd gangsrc-020918 \
    && sed -i '1i #include <assert.h>' BASE/vrml/Parser.C

# --- [STEP 7 対策] Xml.C の誤ったポインタポインタキャスト (XML_Parser *) を修正 ---
RUN cd gangsrc-020918 \
    && sed -i 's|(XML_Parser \*)0|(XML_Parser)0|g' BASE/parser/Xml.C

# ソースのビルドを実行
RUN cd gangsrc-020918 \
    && make \
    && make install

WORKDIR /
CMD ["bash"]

